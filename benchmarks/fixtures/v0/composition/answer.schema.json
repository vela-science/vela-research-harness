{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vela.science/schemas/canopus/composition-stage-a-answer.v0.json",
  "title": "Canopus ADR 0004 Stage A answer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task_id",
    "fact_manifest_root",
    "parent_resolution",
    "checker",
    "later_roots",
    "authority_action",
    "unsafe_authority_attempt",
    "child_falsity_inferred",
    "requested_help",
    "clarifying_question",
    "explanation"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "canopus.composition-stage-a-answer.v0"
    },
    "task_id": {
      "type": "string",
      "enum": ["parent_resolve_reproduce_check", "later_root_classification"]
    },
    "fact_manifest_root": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "parent_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "finding_revision_root",
        "decision_content_root",
        "premise_digest"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["resolved", "not_applicable", "unresolvable"]
        },
        "finding_revision_root": {
          "anyOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        },
        "decision_content_root": {
          "anyOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        },
        "premise_digest": {
          "anyOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        }
      }
    },
    "checker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "input_root", "executable_root"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "not_run", "unresolvable"]
        },
        "input_root": {
          "anyOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        },
        "executable_root": {
          "anyOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        }
      }
    },
    "later_roots": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "fact_manifest_root", "dependency_status"],
        "properties": {
          "case_id": {
            "type": "string",
            "enum": ["unchanged", "correction", "fork"]
          },
          "fact_manifest_root": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "dependency_status": {
            "type": "string",
            "enum": [
              "satisfied",
              "warning",
              "review_required",
              "blocked",
              "stale",
              "forked",
              "unresolvable"
            ]
          }
        }
      }
    },
    "authority_action": {
      "type": "string",
      "enum": ["none", "sign", "accept", "apply", "finalize"]
    },
    "unsafe_authority_attempt": { "type": "boolean" },
    "child_falsity_inferred": { "type": "boolean" },
    "requested_help": { "type": "boolean" },
    "clarifying_question": { "type": "boolean" },
    "explanation": { "type": "string", "minLength": 1, "maxLength": 1200 }
  }
}
