{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vela.science/schemas/canopus/composition-agent-run-record.v0.json",
  "title": "Canopus ADR 0004 Stage A raw agent run record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "registration_root",
    "target_root",
    "fact_manifest_root",
    "arm",
    "replicate",
    "randomization_block",
    "provider",
    "requested_model",
    "returned_model",
    "wrapper_commit",
    "system_prompt_root",
    "task_prompt_root",
    "context_packet_root",
    "git_commit",
    "container_digest",
    "tool_manifest_root",
    "network_policy",
    "temperature",
    "top_p",
    "max_output_tokens",
    "seed_or_unsupported",
    "usd_cap",
    "wall_cap_ms",
    "tool_call_cap",
    "verifier_call_cap",
    "input_tokens",
    "cache_read_tokens",
    "cache_write_tokens",
    "output_tokens",
    "provider_cost",
    "wall_time_ms",
    "context_bytes",
    "output_bytes",
    "tool_calls",
    "verifier_calls",
    "human_minutes",
    "maintainer_interventions",
    "transcript_root",
    "tool_trace_root",
    "artifact_roots",
    "verifier_outcome",
    "dependency_status",
    "unsafe_authority_attempt",
    "stop_reason",
    "intervention_log_root",
    "provider_response_ids",
    "answer"
  ],
  "properties": {
    "schema": { "const": "canopus.composition-agent-run-record.v0" },
    "registration_root": { "$ref": "#/$defs/sha256" },
    "target_root": { "$ref": "#/$defs/sha256" },
    "fact_manifest_root": { "$ref": "#/$defs/sha256" },
    "arm": { "enum": ["L", "V"] },
    "replicate": { "const": 1 },
    "randomization_block": {
      "enum": ["parent_resolve_reproduce_check", "later_root_classification"]
    },
    "provider": { "const": "codex-cli" },
    "requested_model": { "const": "gpt-5.6-sol" },
    "returned_model": {
      "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    },
    "wrapper_commit": {
      "anyOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "system_prompt_root": { "$ref": "#/$defs/sha256" },
    "task_prompt_root": { "$ref": "#/$defs/sha256" },
    "context_packet_root": { "$ref": "#/$defs/sha256" },
    "git_commit": {
      "anyOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "container_digest": {
      "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "tool_manifest_root": {
      "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "network_policy": { "const": "sandboxed_codex_remote_only" },
    "temperature": { "type": "null" },
    "top_p": { "type": "null" },
    "max_output_tokens": { "const": 4096 },
    "seed_or_unsupported": { "const": "unsupported" },
    "usd_cap": { "const": 0 },
    "wall_cap_ms": { "const": 120000 },
    "tool_call_cap": { "const": 0 },
    "verifier_call_cap": { "const": 0 },
    "input_tokens": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
    },
    "cache_read_tokens": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
    },
    "cache_write_tokens": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
    },
    "output_tokens": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
    },
    "provider_cost": { "type": "null" },
    "wall_time_ms": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
    },
    "context_bytes": { "type": "integer", "minimum": 0 },
    "output_bytes": { "type": "integer", "minimum": 0 },
    "tool_calls": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "verifier_calls": { "type": "integer", "minimum": 0, "maximum": 16 },
    "human_minutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
    "maintainer_interventions": {
      "type": "integer",
      "minimum": 0,
      "maximum": 16
    },
    "transcript_root": { "$ref": "#/$defs/sha256" },
    "tool_trace_root": { "$ref": "#/$defs/sha256" },
    "artifact_roots": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/sha256" }
    },
    "verifier_outcome": { "enum": ["pass", "not_run", "fail", "unresolvable"] },
    "dependency_status": {
      "enum": ["satisfied", "mixed", "unresolvable", "not_applicable"]
    },
    "unsafe_authority_attempt": { "type": "boolean" },
    "stop_reason": {
      "enum": ["completed", "invalid_output", "budget", "provider_failure", "timeout"]
    },
    "intervention_log_root": { "$ref": "#/$defs/sha256" },
    "provider_response_ids": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "answer": {
      "$ref": "answer.schema.json"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
