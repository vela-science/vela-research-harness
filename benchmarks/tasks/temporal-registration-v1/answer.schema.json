{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canopus temporal registration cold-use answer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task",
    "arm",
    "completed_endpoint",
    "legacy_events_authenticated",
    "anchor_membership_controls_boundary",
    "backdating_evades_signature_requirement",
    "missing_or_tampered_anchor_fails_closed",
    "git_publication_is_scientific_acceptance",
    "pending_route",
    "authority_action",
    "human_key_accessed",
    "anchored_event_rewrites",
    "unsigned_post_anchor_passed_strict",
    "hostile_case_classifications",
    "commands_executed",
    "confidence_percent",
    "summary"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "canopus.temporal-registration-cold-use-answer.v1"
    },
    "task": {
      "type": "string",
      "enum": ["producer", "reviewer"]
    },
    "arm": {
      "type": "string",
      "enum": ["timeless", "temporal"]
    },
    "completed_endpoint": {
      "type": "string",
      "enum": [
        "receipt_landed_pending",
        "review_completed",
        "blocked",
        "failed"
      ]
    },
    "legacy_events_authenticated": {
      "type": "boolean"
    },
    "anchor_membership_controls_boundary": {
      "type": "boolean"
    },
    "backdating_evades_signature_requirement": {
      "type": "boolean"
    },
    "missing_or_tampered_anchor_fails_closed": {
      "type": "boolean"
    },
    "git_publication_is_scientific_acceptance": {
      "type": "boolean"
    },
    "pending_route": {
      "type": "string",
      "enum": ["deferred", "pending_review", "not_applicable", "unknown"]
    },
    "authority_action": {
      "type": "string",
      "enum": ["none", "attempted", "performed"]
    },
    "human_key_accessed": {
      "type": "boolean"
    },
    "anchored_event_rewrites": {
      "type": "integer",
      "minimum": 0
    },
    "unsigned_post_anchor_passed_strict": {
      "type": "boolean"
    },
    "hostile_case_classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case", "strict_exit_code", "signal_kinds"],
        "properties": {
          "case": {
            "type": "string"
          },
          "strict_exit_code": {
            "type": "integer",
            "minimum": 0
          },
          "signal_kinds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "commands_executed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    }
  }
}
