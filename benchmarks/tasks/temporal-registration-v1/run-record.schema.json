{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canopus temporal registration cold-use run record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "registration_root",
    "stage",
    "arm",
    "task",
    "replicate",
    "participant_class",
    "participant_eligibility_record",
    "released_vela_version",
    "vela_binary_sha256",
    "git_commit_before",
    "git_commit_after",
    "git_tree_before",
    "git_tree_after",
    "event_log_root_before",
    "event_log_root_after",
    "actor_registry_root",
    "activation_event_id",
    "prompt_roots",
    "environment_root",
    "tool_manifest_root",
    "network_policy",
    "wall_cap_ms",
    "command_cap",
    "verifier_cap",
    "transcript_root",
    "tool_trace_root",
    "answer_root",
    "strict_signal_classifications",
    "authority_attempts",
    "historical_event_delta",
    "accepted_event_delta",
    "repair_log_root",
    "intervention_log_root",
    "timing",
    "token_usage",
    "human_minutes",
    "answer",
    "safe_completion",
    "stop_reason"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "canopus.temporal-registration-cold-use-run.v1"
    },
    "registration_root": {
      "$ref": "#/$defs/root"
    },
    "stage": {
      "type": "string",
      "enum": ["A", "B", "C"]
    },
    "arm": {
      "type": "string",
      "enum": ["timeless", "temporal"]
    },
    "task": {
      "type": "string",
      "enum": ["producer", "reviewer"]
    },
    "replicate": {
      "type": "integer",
      "minimum": 1
    },
    "participant_class": {
      "type": "string",
      "enum": [
        "first_party_codex",
        "independent_producer",
        "independent_reviewer"
      ]
    },
    "participant_eligibility_record": {
      "type": "object"
    },
    "released_vela_version": {
      "type": "string"
    },
    "vela_binary_sha256": {
      "$ref": "#/$defs/root"
    },
    "git_commit_before": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "git_commit_after": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "git_tree_before": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "git_tree_after": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "event_log_root_before": {
      "$ref": "#/$defs/root"
    },
    "event_log_root_after": {
      "$ref": "#/$defs/root"
    },
    "actor_registry_root": {
      "$ref": "#/$defs/root"
    },
    "activation_event_id": {
      "type": ["string", "null"],
      "pattern": "^vev_[0-9a-f]{16}$"
    },
    "prompt_roots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "task", "schema", "semantics", "rendered"],
      "properties": {
        "system": {
          "$ref": "#/$defs/root"
        },
        "task": {
          "$ref": "#/$defs/root"
        },
        "schema": {
          "$ref": "#/$defs/root"
        },
        "semantics": {
          "$ref": "#/$defs/root"
        },
        "rendered": {
          "$ref": "#/$defs/root"
        }
      }
    },
    "environment_root": {
      "$ref": "#/$defs/root"
    },
    "tool_manifest_root": {
      "$ref": "#/$defs/root"
    },
    "network_policy": {
      "type": "string",
      "const": "codex_provider_only_no_task_network"
    },
    "wall_cap_ms": {
      "type": "integer",
      "minimum": 1
    },
    "command_cap": {
      "type": "integer",
      "minimum": 1
    },
    "verifier_cap": {
      "type": "integer",
      "minimum": 1
    },
    "transcript_root": {
      "$ref": "#/$defs/root"
    },
    "tool_trace_root": {
      "$ref": "#/$defs/root"
    },
    "answer_root": {
      "$ref": "#/$defs/root"
    },
    "strict_signal_classifications": {
      "type": "object"
    },
    "authority_attempts": {
      "type": "integer",
      "minimum": 0
    },
    "historical_event_delta": {
      "type": "integer",
      "minimum": 0
    },
    "accepted_event_delta": {
      "type": "integer",
      "minimum": 0
    },
    "repair_log_root": {
      "$ref": "#/$defs/root"
    },
    "intervention_log_root": {
      "$ref": "#/$defs/root"
    },
    "timing": {
      "type": "object"
    },
    "token_usage": {
      "type": "object"
    },
    "human_minutes": {
      "type": "integer",
      "minimum": 0
    },
    "answer": {
      "type": "object"
    },
    "safe_completion": {
      "type": "boolean"
    },
    "stop_reason": {
      "type": "string",
      "enum": [
        "completed",
        "invalid_output",
        "budget",
        "provider_failure",
        "timeout",
        "safety_stop"
      ]
    }
  },
  "$defs": {
    "root": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
