{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_base",
    "base_state",
    "next_action",
    "must_not_claim",
    "rejected_routes",
    "explanation"
  ],
  "properties": {
    "selected_base": { "enum": ["alpha", "beta", "gamma"] },
    "base_state": { "enum": ["accepted", "pending_review", "draft"] },
    "next_action": { "enum": ["extend_beta", "extend_alpha", "repair_gamma", "wait"] },
    "must_not_claim": {
      "enum": ["alpha_is_accepted", "beta_is_accepted", "gamma_verifier_passed", "nothing"]
    },
    "rejected_routes": {
      "type": "array",
      "maxItems": 3,
      "items": { "enum": ["alpha_pending", "beta_accepted", "gamma_verifier_failed"] }
    },
    "explanation": { "type": "string", "minLength": 1, "maxLength": 800 }
  }
}
